{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenClaw Config",
  "version": "1.0.0",
  "identifier": "com.openclaw.config-ui",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3300",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw Config UI",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/server"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "../public/favicon.svg"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
