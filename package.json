{
  "name": "openclaw-config-ui",
  "version": "1.0.0",
  "description": "OpenClaw Configuration Management UI",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build:server": "node scripts/build-sidecar.js",
    "build:server:bun": "bun build server.js --compile --minify --target=bun-windows-x64 --outfile=src-tauri/binaries/server-x86_64-pc-windows-msvc.exe && bun build server.js --compile --minify --target=bun-linux-x64 --outfile=src-tauri/binaries/server-x86_64-unknown-linux-gnu",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:server && tauri build"
  },
  "bin": "server.js",
  "pkg": {
    "assets": ["public/**/*"],
    "scripts": ["server.js"]
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "autoprefixer": "^10.4.17",
    "pkg": "^5.8.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  }
}
